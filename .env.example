WHATSAPP_OTP_TEMPLATE_LANGUAGE=en
WHATSAPP_OTP_INCLUDE_COPY_CODE_BUTTON=1
WHATSAPP_WEBHOOK_VERIFY_TOKEN=mentorkhoj_whatsapp_verify

SOFTWARE_ID=MzI3OTE2MzE=
BUYER_USERNAME=
PURCHASE_CODE=

# MentorKhoj site + admin notifications (seminar/internship emails)
MENTORKHOJ_SITE_URL=https://www.mentorkhoj.com
