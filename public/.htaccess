<IfModule mod_rewrite.c>
    RewriteEngine On

    # Fix CORS for Storage Files
    <IfModule mod_headers.c>
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Header set Access-Control-Allow-Headers "Content-Type, Authorization"
    </IfModule>

    # Redirect /storage/ to /public/storage/
    RewriteCond %{REQUEST_URI} ^/storage/(.*)$ [NC]
    RewriteCond %{DOCUMENT_ROOT}/public/storage/%1 -f
    RewriteRule ^storage/(.*)$ /public/storage/$1 [L]

    # Redirect all other non-static requests to Laravel index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

